[run]
relative_files = True
source = src
omit = 
    src/core/gateway/capture_gateway.py
    src/core/usecase/capture_usecase.py
    src/infrastructure/configuration/settings.py
    src/infrastructure/configuration/logging.py
    src/infrastructure/configuration/rabbitmq_config.py  
    src/main.py
    **/__init__.py

[paths]
source =
    src