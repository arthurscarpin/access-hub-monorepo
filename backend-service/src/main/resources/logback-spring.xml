<configuration>
    <property name="LOG_PATH" value="${LOG_PATH:-${user.dir}/backend-service/logs}"/>
    <property name="APP_NAME" value="access-control-system"/>

    <!-- Appender de Console: Sempre ativo -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Appender de Arquivo: Criado apenas se NÃO for prod e test -->
    <springProfile name="!prod &amp; !test">
        <appender name="JSON_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
                <fileNamePattern>${LOG_PATH}/%d{yyyyMMdd}.ndjson</fileNamePattern>
                <maxHistory>30</maxHistory>
            </rollingPolicy>
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <customFields>{"app":"${APP_NAME}","env":"dev"}</customFields>
            </encoder>
        </appender>
    </springProfile>

    <!-- Configuração do ROOT -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        
        <!-- Referência ao arquivo condicional -->
        <springProfile name="!prod &amp; !test">
            <appender-ref ref="JSON_FILE"/>
        </springProfile>
    </root>

    <!-- Nível de log de debug para profiles -->
    <springProfile name="!prod &amp; !test">
        <logger name="com.arthurscarpin" level="DEBUG"/>
    </springProfile>
    
    <!-- Nível de log info para test e prod -->
    <springProfile name="prod | test">
        <logger name="com.arthurscarpin" level="INFO"/>
    </springProfile>

</configuration>